# ─── Telegram ───────────────────────────────────────────────
# Get this from @BotFather
BOT_TOKEN=123456:ABCDEF_your_bot_token_here
# Comma-separated Telegram user IDs that get admin access (find yours via @userinfobot).
ADMIN_IDS=111111111
# Channel the bot posts announcements to (@username or -100… id). Bot must be admin there.
POST_CHANNEL=
# Public-facing contacts shown in the bot description + Help.
SUPPORT_CONTACT=
CHANNEL_USERNAME=

# ─── HeroSMS ────────────────────────────────────────────────
HEROSMS_API_KEY=your_herosms_api_key_here
HEROSMS_BASE_URL=https://hero-sms.com/stubs/handler_api.php

# ─── eSIM Access (esimaccess.com) — optional, enables the eSIM product ──────
ESIM_ACCESS_CODE=
ESIM_SECRET_KEY=
ESIM_BASE_URL=https://api.esimaccess.com

# ─── Pricing (smart two-knob model) ─────────────────────────
# SMS/rent: customer pays (floor + BID_PREMIUM_PERCENT) + MARKUP_PERCENT.
MARKUP_PERCENT=20
BID_PREMIUM_PERCENT=10
MIN_BID=0
# eSIM: customer pays cost + this %.
ESIM_COMMISSION_PERCENT=15

# ─── Crypto payments — Heleket (preferred) ──────────────────
HELEKET_MERCHANT=
HELEKET_API_KEY=
# ─── Crypto payments — Crypto Pay / @CryptoBot (fallback) ───
CRYPTOBOT_TOKEN=
CRYPTOBOT_TESTNET=false
CRYPTOBOT_ASSET=USDT

# ─── Behaviour ──────────────────────────────────────────────
ORDER_TIMEOUT_MIN=20
POLL_INTERVAL_SEC=5
PAYMENT_POLL_INTERVAL_SEC=12
QUEUE_RETRY_SEC=60
QUEUE_TIMEOUT_MIN=60
MIN_TOPUP=1
CURRENCY_SYMBOL=$

# ─── Storage ────────────────────────────────────────────────
DB_URL=sqlite+aiosqlite:///smsbot.db
